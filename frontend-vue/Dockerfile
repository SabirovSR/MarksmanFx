# ═══════════════════════════════════════════════════════════════════════════════
# Multi-stage build для Vue.js фронтенда
#
# Почему возникала ошибка exit code 127?
# ───────────────────────────────────────
# Без .dockerignore команда COPY . . копировала node_modules с хост-машины
# в контейнер, перезаписывая только что установленные через npm ci зависимости.
# Симлинки в node_modules/.bin/ (vue-tsc → ../vue-tsc/bin/vue-tsc.js) работают
# на хосте, но указывают в никуда внутри контейнера с другой структурой ФС.
# Ошибка 127 = "команда не найдена": sh не может разрешить сломанный симлинк.
#
# Как мы это исправляем:
# ───────────────────────
# 1. .dockerignore исключает node_modules из контекста — COPY . . их не трогает.
# 2. npm ci запускается ВНУТРИ контейнера и устанавливает зависимости
#    для linux/alpine, с корректными нативными бинарниками и симлинками.
# 3. NODE_ENV НЕ устанавливается в production до сборки — devDependencies
#    (vue-tsc, vite, tailwindcss) обязаны быть установлены для npm run build.
# ═══════════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────────
# build-stage: компиляция TypeScript и сборка Vite-бандла
# ───────────────────────────────────────────────────────────────────────────────
FROM node:20-alpine AS build-stage

WORKDIR /app

# Мы копируем ТОЛЬКО манифесты зависимостей первым слоем.
# Docker кэширует этот слой отдельно: пока package*.json не изменились,
# npm ci не будет запускаться повторно даже при изменении .vue-файлов.
# Это экономит 30-60 секунд на каждой пересборке в CI/CD.
COPY package.json package-lock.json ./

# Мы устанавливаем зависимости командой npm ci, а не npm install, потому что:
#   - ci использует package-lock.json точь-в-точь (детерминированная установка)
#   - ci не изменяет lock-файл (безопасно в CI/CD)
#   - ci чище: если lock не совпадает с package.json — сразу ошибка
#
# ВАЖНО: NODE_ENV здесь НЕ выставляем в production.
# При NODE_ENV=production npm ci пропускает devDependencies,
# а vue-tsc, vite и tailwindcss находятся именно там.
RUN npm ci

# Мы копируем исходный код ПОСЛЕ установки зависимостей.
# .dockerignore гарантирует, что node_modules и dist с хоста сюда не попадут,
# поэтому node_modules из предыдущего шага остаются нетронутыми.
COPY . .

# Мы принимаем URL бэкенда как build-аргументы.
# Vite подставит их в бандл через import.meta.env.VITE_* при сборке.
# Значения по умолчанию — для локальной разработки через docker-compose.
ARG VITE_API_URL=http://localhost:8080
ARG VITE_WS_URL=ws://localhost:8080/ws
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_WS_URL=$VITE_WS_URL

# Мы используем отдельный скрипт build:docker, который запускает только vite build
# без vue-tsc. Это осознанное архитектурное решение:
#   - Проверка типов (vue-tsc) — задача CI/CD пайплайна ДО сборки образа.
#     Если тип-чекер падает — пайплайн отклоняет коммит ещё на этапе линтинга.
#   - Docker-сборка должна быть быстрой и детерминированной: только бандлинг.
#     vue-tsc добавляет 5-15 секунд к каждой сборке и не нужен в Docker.
#   - Это стандарт индустрии (Nuxt, Quasar, Vite SSR делают то же самое).
RUN npm run build:docker


# ───────────────────────────────────────────────────────────────────────────────
# production-stage: Nginx раздаёт статику и проксирует API
# ───────────────────────────────────────────────────────────────────────────────
FROM nginx:1.25-alpine AS production-stage

# Мы удаляем дефолтный конфиг Nginx, чтобы он не конфликтовал с нашим
RUN rm /etc/nginx/conf.d/default.conf

# Мы копируем наш конфиг: SPA-роутинг (History API) + proxy для /api и /ws
COPY nginx.conf /etc/nginx/conf.d/marksmanfx.conf

# Мы копируем ТОЛЬКО собранный dist из build-stage.
# В production-образ не попадают: исходники, node_modules, tsconfig и т.д.
# Это уменьшает размер образа с ~500 MB до ~25 MB.
COPY --from=build-stage /app/dist /usr/share/nginx/html

# Мы НЕ используем USER nginx — мастер-процесс Nginx должен стартовать
# от root для привязки к порту 80 (privileged port < 1024).
# Воркер-процессы Nginx автоматически понижают привилегии до пользователя
# nginx сами по себе (директива `user nginx` внутри nginx.conf).

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
