{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl":        ".",
    "paths":          { "@/*": ["./src/*"] },
    "types":          ["vite/client"],
    // Мы отключаем проверку типов в .d.ts файлах node_modules.
    // Это стандартная практика для Vue/Vite проектов: версионные конфликты
    // между @vue/tsconfig и vite/types/importGlob.d.ts (Worker type) дают
    // ложноположительные ошибки, не связанные с нашим кодом.
    "skipLibCheck":   true
  }
}
