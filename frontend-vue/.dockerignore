# ─── Зависимости ──────────────────────────────────────────────────────────────
# Мы исключаем node_modules из Docker-контекста — это ГЛАВНАЯ причина ошибки 127.
# Без этого файла команда COPY . . копирует node_modules с хост-машины в контейнер.
# Симлинки в node_modules/.bin/ (например, vue-tsc -> ../vue-tsc/bin/vue-tsc.js)
# ссылаются на относительные пути, которые работают на хосте, но не существуют
# внутри контейнера => exit code 127 (бинарник "не найден").
# Зависимости ВСЕГДА должны устанавливаться внутри контейнера через npm ci.
node_modules

# ─── Артефакты сборки ─────────────────────────────────────────────────────────
# Мы исключаем dist — он создаётся внутри контейнера на build-stage.
# Копирование локального dist сломало бы кэш слоёв и содержало бы устаревшие файлы.
dist

# ─── Переменные окружения ─────────────────────────────────────────────────────
# Мы не передаём .env-файлы в контейнер — секреты должны поступать
# через ARG/ENV в Dockerfile или через docker-compose environment.
.env
.env.*
.env.local
.env.*.local

# ─── Git ──────────────────────────────────────────────────────────────────────
# Мы исключаем .git — история репозитория не нужна для сборки
# и только раздувает Docker-контекст (может быть сотни МБ).
.git
.gitignore
.gitattributes

# ─── Логи и временные файлы ───────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Артефакты IDE и ОС ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode
.idea
*.swp
*.swo

# ─── Тесты ────────────────────────────────────────────────────────────────────
# Мы не включаем тесты в образ — они запускаются отдельно в CI/CD
**/*.test.ts
**/*.spec.ts
coverage

# ─── TypeScript build-cache ───────────────────────────────────────────────────
# Мы исключаем кэши vue-tsc/tsc — они не нужны при чистой сборке в контейнере
*.tsbuildinfo
