<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.marksmanfx.client.ui.login.LoginController"
            fx:id="rootPane"
            styleClass="root-pane"
            prefWidth="520" prefHeight="560">

    <!-- Пользовательская шапка -->
    <top>
        <HBox fx:id="titleBar" styleClass="toolbar" alignment="CENTER_LEFT" spacing="8">
            <padding><Insets top="8" right="8" bottom="8" left="16"/></padding>
            <Label text="⚔ Меткий стрелок — сетевая игра" styleClass="toolbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="—" onAction="#onMinimize" styleClass="btn-window-min" focusTraversable="false"/>
            <Button text="✕" onAction="#onClose"    styleClass="btn-window-close" focusTraversable="false"/>
        </HBox>
    </top>

    <!-- Форма входа / регистрации -->
    <center>
        <StackPane>
            <VBox alignment="CENTER" spacing="12" maxWidth="360">
                <padding><Insets top="24" right="48" bottom="32" left="48"/></padding>

                <Label text="Войти в игру" styleClass="section-label"/>

                <!-- Поле логина (имя пользователя) -->
                <Label text="Логин" styleClass="field-label"/>
                <TextField fx:id="usernameField" promptText="Введите логин"
                           styleClass="input-field" maxWidth="Infinity"/>

                <!-- Поле пароля — PasswordField скрывает символы -->
                <Label text="Пароль" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="Введите пароль"
                               styleClass="input-field" maxWidth="Infinity"/>

                <!-- Адрес сервера (HTTP URL) -->
                <Label text="Адрес сервера" styleClass="field-label"/>
                <TextField fx:id="serverUrlField" promptText="http://localhost:8080"
                           styleClass="input-field" maxWidth="Infinity"/>

                <!-- Чекбокс «Запомнить меня» — управляет сохранением JWT в Preferences -->
                <CheckBox fx:id="rememberMeBox" text="Запомнить меня"
                          styleClass="remember-me-check" selected="true"/>

                <!-- Кнопки входа и регистрации -->
                <Button fx:id="loginButton" text="Войти"
                        onAction="#onLogin"
                        styleClass="btn-accent" maxWidth="Infinity"/>

                <Button fx:id="registerButton" text="Зарегистрироваться"
                        onAction="#onRegister"
                        styleClass="btn-secondary" maxWidth="Infinity"/>

                <!-- Метка статуса: ошибки, прогресс -->
                <Label fx:id="statusLabel" text="" styleClass="status-label" wrapText="true"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
