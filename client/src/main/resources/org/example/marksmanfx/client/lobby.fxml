<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="620" prefWidth="920" styleClass="root-pane" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.marksmanfx.client.ui.lobby.LobbyController">

    <!-- Пользовательская шапка -->
    <top>
        <HBox fx:id="titleBar" alignment="CENTER_LEFT" spacing="16" styleClass="toolbar">
            <padding><Insets bottom="10" left="16" right="8" top="10" /></padding>

            <Label styleClass="toolbar-title" text="⚔ Меткий стрелок" />
            <Label fx:id="welcomeLabel" styleClass="toolbar-subtitle" text="" />
            <Region HBox.hgrow="ALWAYS" />

            <!-- Кнопки окна -->
            <Button focusTraversable="false" onAction="#onMinimize" styleClass="btn-window-min" text="—" />
            <Button focusTraversable="false" onAction="#onClose" styleClass="btn-window-close" text="✕" />
        </HBox>
    </top>

    <!-- Список комнат -->
    <center>
        <VBox spacing="12" styleClass="content-pane">
            <padding><Insets bottom="20" left="24" right="24" top="20" /></padding>

            <Label styleClass="section-label" text="Доступные комнаты" />

            <TableView fx:id="roomTable" styleClass="room-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colName" prefWidth="340" text="Название" />
                    <TableColumn fx:id="colPlayers" prefWidth="100" text="Игроки" />
                    <TableColumn fx:id="colStatus" prefWidth="430.0" text="Статус" />
                </columns>
                <placeholder>
                    <Label styleClass="placeholder-label" text="Нет доступных комнат. Создайте первую!" />
                </placeholder>
            </TableView>

            <!-- Кнопки действий -->
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#onCreateRoom" styleClass="btn-accent" text="+ Создать комнату" />
                <Button fx:id="joinButton" disable="true" onAction="#onJoinRoom" styleClass="btn-primary" text="Войти в комнату" />
                <Button onAction="#onQuickMatch" styleClass="btn-primary" text="⚡ Быстрый матч" />
            </HBox>

            <Label fx:id="statusLabel" styleClass="status-label" text="" />
        </VBox>
    </center>
</BorderPane>
